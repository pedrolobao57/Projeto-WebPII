    {
      "name": "Reservations",
      "item": [
        {
          "name": "Create Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.novaReserva && response.novaReserva.id_reserva) {",
                  "    pm.collectionVariables.set(\"reservationId\", response.novaReserva.id_reserva.toString());",
                  "    pm.collectionVariables.set(\"spotId\", response.novaReserva.id_vaga.toString());",
                  "    console.log(\"Saved reservationId and spotId to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_vaga\": {{spotId}},\n  \"data_inicio\": \"2026-05-30T10:00:00.000Z\",\n  \"data_fim\": \"2026-05-30T12:00:00.000Z\",\n  \"id_veiculo\": {{vehicleId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/reservations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations"
              ]
            },
            "description": "Places a pending reservation on a parking spot. The spot's state will change to 'RESERVADO'."
          },
          "response": []
        },
        {
          "name": "List Reservations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me/reservations",
