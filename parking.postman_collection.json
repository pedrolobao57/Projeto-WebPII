{
  "info": {
    "_postman_id": "4b54e3d3-1c39-4d69-b5fe-f018e7e1e69b",
    "name": "ParkSmart API",
    "description": "API collection for ParkSmart - Parking management system.\n\n### Authentication\nProtected requests inherit Bearer Token auth from the collection, using the `{{token}}` variable.\nWhen you call the **Login** request, a Postman script automatically saves the returned token into `{{token}}` so subsequent protected calls work seamlessly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth & User",
      "item": [
        {
          "name": "Sign Up (Create User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "    pm.collectionVariables.set(\"userId\", response.id.toString());",
                  "    console.log(\"Saved registered userId to variables!\");",
                  "}",
                  "if (response.vehicles && response.vehicles.length > 0) {",
                  "    pm.collectionVariables.set(\"vehicleId\", response.vehicles[0].id_veiculo.toString());",
                  "    console.log(\"Saved registered vehicleId to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"securepassword123\",\n  \"phone\": \"+351912345678\",\n  \"vehicles\": [\n    {\n      \"plate\": \"AA-00-BB\",\n      \"brand\": \"Tesla\",\n      \"model\": \"Model 3\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Registers a new user and optionally their vehicle(s)."
          },
          "response": []
        },
        {
          "name": "Sign Up (Invalid Plate)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"securepassword123\",\n  \"phone\": \"+351912345678\",\n  \"vehicles\": [\n    {\n      \"plate\": \"AA-123-BB\",\n      \"brand\": \"Tesla\",\n      \"model\": \"Model 3\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Attempt to sign up with an invalid plate format. Should fail with HTTP 400 and message 'Matrícula não identificada.'"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set(\"token\", response.token);",
                  "    if (response.refreshToken) {",
                  "        pm.collectionVariables.set(\"refreshToken\", response.refreshToken);",
                  "    }",
                  "    pm.collectionVariables.set(\"userId\", response.user.id.toString());",
                  "    if (response.user.vehicles && response.user.vehicles.length > 0) {",
                  "        pm.collectionVariables.set(\"vehicleId\", response.user.vehicles[0].id_veiculo.toString());",
                  "    }",
                  "    console.log(\"Saved login token, refresh token, and user/vehicle details successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente.1@example.com\",\n  \"password\": \"password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "login"
              ]
            },
            "description": "Authenticates user credentials. Returns an access token `fake-jwt-token-{id}` and a refresh token `fake-refresh-token-{id}` which are automatically saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set(\"token\", response.token);",
                  "    pm.collectionVariables.set(\"refreshToken\", response.refreshToken);",
                  "    console.log(\"Tokens refreshed and updated successfully!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "refresh"
              ]
            },
            "description": "Uses the refresh token to request a new access token."
          },
          "response": []
        },
