    {
      "name": "Simulation",
      "item": [
        {
          "name": "Register Entry (Barrier Simulation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.entrada && response.entrada.id_estacionamento) {",
                  "    pm.collectionVariables.set(\"estacionamentoId\", response.entrada.id_estacionamento.toString());",
                  "    console.log(\"Saved simulated estacionamentoId to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_veiculo\": {{vehicleId}},\n  \"id_vaga\": {{spotId}},\n  \"id_reserva\": {{reservationId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/estacionamentos/entrada",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "estacionamentos",
                "entrada"
              ]
            },
            "description": "Simulates a vehicle passing the entry barrier of the parking structure. Marks the designated spot as 'OCUPADO'."
          },
          "response": []
        },
        {
          "name": "Register Exit (Barrier Simulation)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_estacionamento\": {{estacionamentoId}},\n  \"id_tarifa\": null,\n  \"metodo_pagamento\": \"MBWAY\",\n  \"id_utilizador\": {{userId}},\n  \"promoCode\": \"Codigo VSKI\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/estacionamentos/saida",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "estacionamentos",
                "saida"
              ]
            },
            "description": "Simulates a vehicle passing the exit barrier. Automatically calculates the duration, processes the exit payment, releases the spot back to 'LIVRE', and updates reservation status to 'CONCLUIDA'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Maintenance",
      "item": [
        {
          "name": "Report Sensor Malfunction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.alertaManutencao && response.alertaManutencao.id_manutencao) {",
                  "    pm.collectionVariables.set(\"maintenanceId\", response.alertaManutencao.id_manutencao.toString());",
                  "    console.log(\"Saved maintenanceId to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_sensor\": {{sensorId}},\n  \"id_gestor\": 41,\n  \"descricao_problema\": \"Sensor failing to register occupied state correctly.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/report",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maintenance",
                "report"
              ]
            },
            "description": "Reports a sensor malfunction. Generates a maintenance request and sets the physical sensor hardware state to 'Avaria'."
          },
          "response": []
        },
        {
          "name": "Conclude Sensor Repair",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_manutencao\": {{maintenanceId}},\n  \"custo_reparacao\": 45.00,\n  \"novo_estado_sensor\": \"LIVRE\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/maintenance/resolve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "maintenance",
                "resolve"
              ]
            },
            "description": "Records completion of a maintenance action. Sets status to 'Resolvido' and restores the sensor back to working status (e.g., 'LIVRE')."
          },
          "response": []
        }
      ]
    },
